# ═════════════════════════════════════════════════════════════════════════════
# PlanificaMe - Archivo de Ejemplo para completar
# ═════════════════════════════════════════════════════════════════════════════
#
# Instrucciones:
# 1. Copiar este archivo como .env
# 2. Reemplazar todos los valores [AQUI] con tus datos reales
# 3. No compartir este archivo (contiene contraseñas)
# 4. Agregar .env al .gitignore
#
# ═════════════════════════════════════════════════════════════════════════════

# SUPABASE (PostgreSQL)
# Obtener de: https://app.supabase.com/project/_/settings/database
DATABASE_URL=postgresql://postgres:[12345]@db.[ID_PROYECTO].supabase.co:5432/postgres

# REDIS (Railway crea uno automático)
# Si usas localmente: redis://localhost:6379/0
REDIS_URL=redis://default:[CONTRASEÑA_REDIS]@[REDIS_HOST]:6379
CELERY_BROKER_URL=redis://default:[CONTRASEÑA_REDIS]@[REDIS_HOST]:6379
CELERY_RESULT_BACKEND=redis://default:[CONTRASEÑA_REDIS]@[REDIS_HOST]:6379

# GMAIL SMTP
# 1. Activar 2FA en https://myaccount.google.com/security
# 2. Ir a App passwords en https://myaccount.google.com/apppasswords
# 3. Seleccionar "Correo" y "Windows/Linux"
# 4. Copiar la contraseña de 16 caracteres
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=[TU_EMAIL@gmail.com]
SMTP_PASSWORD=[CONTRASEÑA_DE_16_CARACTERES]
SENDER_EMAIL=[TU_EMAIL@gmail.com]
SENDER_NAME=PlanificaMe

# FRONTEND
# URL de tu aplicación en Vercel
FRONTEND_URL=https://[TU_PROYECTO].vercel.app

# APLICACIÓN
DEBUG=False
