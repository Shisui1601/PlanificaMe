# ═════════════════════════════════════════════════════════════════════════════
# SUPABASE (PostgreSQL)
# ═════════════════════════════════════════════════════════════════════════════
# Obtén la URL de tu base de datos Supabase desde:
# https://app.supabase.com/project/_/settings/database
DATABASE_URL=postgresql://user:12345@host:5432/database


# ═════════════════════════════════════════════════════════════════════════════
# REDIS (Para Celery)
# ═════════════════════════════════════════════════════════════════════════════
# En Railway, se auto-configura. Localmente, usa:
# REDIS_URL=redis://localhost:6379/0
REDIS_URL=redis://default:password@host:6379
CELERY_BROKER_URL=redis://default:password@host:6379
CELERY_RESULT_BACKEND=redis://default:password@host:6379


# ═════════════════════════════════════════════════════════════════════════════
# GMAIL SMTP (Para envío de correos)
# ═════════════════════════════════════════════════════════════════════════════
# Para Gmail, necesitas generar una "Contraseña de Aplicación":
# 1. Activa 2FA en tu cuenta Google
# 2. Ve a: https://myaccount.google.com/apppasswords
# 3. Crea una contraseña para "Correo" en "Windows/Linux"
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=tu_contraseña_de_aplicacion
SENDER_EMAIL=tu_email@gmail.com
SENDER_NAME=PlanificaMe


# ═════════════════════════════════════════════════════════════════════════════
# FRONTEND
# ═════════════════════════════════════════════════════════════════════════════
# URL del frontend (Vercel)
FRONTEND_URL=https://tu-proyecto.vercel.app


# ═════════════════════════════════════════════════════════════════════════════
# APLICACIÓN
# ═════════════════════════════════════════════════════════════════════════════
DEBUG=False
APP_NAME=PlanificaMe
APP_VERSION=1.0.0
